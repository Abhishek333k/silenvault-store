---
pagination:
  data: products
  size: 1
  alias: product
permalink: "item/{{ product.ID }}/index.html"
---
<!DOCTYPE html>
<html lang="en" style="cursor: none !important;">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ product.Title }} | SilenVault Store</title>
    <meta name="description" content="{{ product.Description }}">
    
    <meta property="og:title" content="{{ product.Title }} | SilenVault">
    <meta property="og:description" content="{{ product.Description }}">
    <meta property="og:type" content="product">
    <meta property="og:url" content="https://silenvault.com/item/{{ product.ID }}/">
    {% if product.mediaFiles.length > 0 %}
    <meta property="og:image" content="https://silenvault.com{{ product.mediaFiles[0] }}">
    <meta name="twitter:image" content="https://silenvault.com{{ product.mediaFiles[0] }}">
    {% endif %}
    <meta name="twitter:card" content="summary_large_image">
    <meta name="theme-color" content="#00F0FF">
    
    <script type="application/ld+json">
    {
        "@context": "https://schema.org/",
        "@type": "Product",
        "name": "{{ product.Title }}",
        "description": "{{ product.Description }}",
        "brand": { "@type": "Brand", "name": "SilenVault" },
        "offers": {
            "@type": "Offer",
            "priceCurrency": "USD",
            "price": "{{ '0.00' if product.Price == 'FREE' else product.Price | replace('$', '') }}",
            "availability": "https://schema.org/InStock"
        }
    }
    </script>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700;900&family=Fira+Code:wght@400;700&display=swap" rel="stylesheet">
    <script src="/assets/js/layout.js" defer></script>
    <script src="https://app.lemonsqueezy.com/js/lemon.js" defer></script>
    <script>
